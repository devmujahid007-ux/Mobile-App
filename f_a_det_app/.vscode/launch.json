{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NeuroScan: Chrome (no Google CDN)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--no-web-resources-cdn",
        "--dart-define=NEUROSCAN_API_URL=http://127.0.0.1:8000"
      ]
    },
    {
      "name": "NeuroScan: Windows desktop",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "windows",
      "toolArgs": [
        "--dart-define=NEUROSCAN_API_URL=http://127.0.0.1:8000"
      ]
    }
  ]
}
