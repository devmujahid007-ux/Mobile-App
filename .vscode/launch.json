{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NeuroScan AI (Flutter, Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "${workspaceFolder}/f_a_det_app/lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--no-web-resources-cdn",
        "--dart-define=NEUROSCAN_API_URL=http://127.0.0.1:8000"
      ]
    },
    {
      "name": "NeuroScan AI (Flutter, Windows)",
      "request": "launch",
      "type": "dart",
      "program": "${workspaceFolder}/f_a_det_app/lib/main.dart",
      "deviceId": "windows",
      "toolArgs": [
        "--dart-define=NEUROSCAN_API_URL=http://127.0.0.1:8000"
      ]
    }
  ]
}
